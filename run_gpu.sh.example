#!/bin/bash
# gaze360 を GPU サーバーで実行するスクリプト（Mac側で実行する）
#
# 使い方:
#   cp run_gpu.sh.example run_gpu.sh
#   # run_gpu.sh 内の変数を編集する
#   bash run_gpu.sh

GUNDAM_USER="your_username"         # GPU サーバーのユーザー名
GUNDAM_HOST="xxx.xxx.xxx.xxx"       # GPU サーバーの IP アドレス
THETA_IP="xxx.xxx.xxx.xxx"          # THETA X の IP（Mac の .env に書いてある値）
TUNNEL_PORT=$((RANDOM + 40000))          # ランダムポート（毎回変わるので競合しない）
STREAM_PORT=$((RANDOM % 1000 + 9000))   # ランダムポート（9000〜9999）
GPU_INDEX=0                         # 使用する GPU 番号

echo "=========================================="
echo "  gaze360 GPU パイプライン 起動"
echo "=========================================="
echo "  トンネル : GPU:${TUNNEL_PORT} → ${THETA_IP}:80"
echo "  映像視聴 : http://${GUNDAM_HOST}:${STREAM_PORT}"
echo "  終了     : Ctrl+C"
echo "=========================================="
echo ""

ssh \
  -o ServerAliveInterval=30 \
  -o ServerAliveCountMax=3 \
  -o ExitOnForwardFailure=yes \
  -R "${TUNNEL_PORT}:${THETA_IP}:80" \
  "${GUNDAM_USER}@${GUNDAM_HOST}" \
  "cd gaze360 && source venv/bin/activate && export CUDA_VISIBLE_DEVICES=${GPU_INDEX} && THETA_IP=localhost:${TUNNEL_PORT} python -m src.pipeline --stream-port ${STREAM_PORT}"
